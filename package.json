{
  "name": "standard-parse",
  "version": "0.4.0",
  "description": "Schema parsing via the Standard Schema spec. Works with Zod, Valibot, Arktype, and more.",
  "homepage": "https://github.com/catena-labs/standard-parse#readme",
  "bugs": "https://github.com/catena-labs/standard-parse/issues",
  "license": "MIT",
  "author": {
    "name": "Catena Labs",
    "url": "https://catenalabs.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/catena-labs/standard-parse.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./test-matchers/vitest": {
      "types": "./dist/test-matchers/vitest.d.mts",
      "default": "./dist/test-matchers/vitest.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check": "pnpm run format:check && pnpm run lint && pnpm test",
    "clean": "git clean -xdf dist node_modules/.cache",
    "fix": "pnpm run format && pnpm run lint:fix",
    "format": "oxfmt",
    "format:check": "pnpm run format --check",
    "lint": "oxlint --type-aware",
    "lint:fix": "pnpm run lint --fix --fix-suggestions",
    "lint:fixall": "pnpm run lint:fix --fix-dangerously",
    "nuke": "pnpm run clean && git clean -xdf node_modules",
    "outdated": "pnpm dlx npm-check-updates --interactive --format group",
    "prepublishOnly": "pnpm run build && pnpm run publint",
    "publint": "pnpm dlx publint@latest",
    "test": "vitest"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "latest",
    "arktype": "^2.2.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "oxlint-tsgolint": "latest",
    "tsdown": "^0.22.0",
    "typescript": "^6",
    "valibot": "^1.3.0",
    "vitest": "^4.1.5",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "arktype": "^2.0.0",
    "valibot": "^1.0.0",
    "vitest": ">=3.2.0",
    "zod": "^3.25.0"
  },
  "peerDependenciesMeta": {
    "arktype": {
      "optional": true
    },
    "valibot": {
      "optional": true
    },
    "vitest": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.32.1"
}
