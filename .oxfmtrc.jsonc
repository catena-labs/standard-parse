{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "embeddedLanguageFormatting": "auto",
  "semi": false,
  "singleQuote": false,
  "trailingComma": "none",
  "tabWidth": 2,
  "printWidth": 80,
  "proseWrap": "always",
  "sortImports": {},
  "sortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": ["**/*.d.ts"]
}
